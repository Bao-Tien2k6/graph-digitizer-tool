# Keep the build context small and the image clean.

# VCS / editor / agent
.git
.gitignore
.claude
*.md

# Python
venv/
__pycache__/
*.pyc
.pytest_cache/

# Frontend — deps and prior builds are rebuilt inside the image
frontend/node_modules/
frontend/dist/

# Test fixtures, ground truth, and generated outputs (not needed at runtime)
tests/
scripts/
docs/

# Large sample workbook — not needed to run the server
Example 1.xlsx

# Local env overrides
.env
